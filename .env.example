# ========== 生产环境配置示例 ==========
# 复制此文件为 .env.local 并修改为你的实际值

# ========== 基础配置 ==========
APP_NAME=MultiGPT Platform
# 生产环境使用你的实际域名
APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NODE_ENV=production

# ========== Supabase 配置 ==========
NEXT_PUBLIC_SUPABASE_URL=你的Supabase项目URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的Supabase匿名密钥

# ========== Stripe 配置 ==========
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=你的Stripe发布密钥
STRIPE_SECRET_KEY=你的Stripe密钥
STRIPE_WEBHOOK_SECRET=你的Stripe webhook密钥

# Stripe价格ID配置
STRIPE_PRO_MONTHLY_PRICE_ID=你的专业版月付价格ID
STRIPE_PRO_ANNUAL_PRICE_ID=你的专业版年付价格ID
STRIPE_TEAM_MONTHLY_PRICE_ID=你的团队版月付价格ID
STRIPE_TEAM_ANNUAL_PRICE_ID=你的团队版年付价格ID

# ========== PayPal 配置 ==========
PAYPAL_CLIENT_ID=你的PayPal客户端ID
PAYPAL_CLIENT_SECRET=你的PayPal客户端密钥
PAYPAL_WEBHOOK_ID=你的PayPal Webhook ID
# 可选：sandbox 或 live（默认为 live）。也可直接设置 PAYPAL_API_BASE
PAYPAL_MODE=sandbox
# PAYPAL_API_BASE=https://api-m.paypal.com
PAYPAL_PRO_MONTHLY_PLAN_ID=你的PayPal专业版月付计划ID
PAYPAL_PRO_ANNUAL_PLAN_ID=你的PayPal专业版年付计划ID
PAYPAL_TEAM_MONTHLY_PLAN_ID=你的PayPal团队版月付计划ID
PAYPAL_TEAM_ANNUAL_PLAN_ID=你的PayPal团队版年付计划ID

# ========== AI Provider 配置 ==========
# OpenAI配置
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=可选的组织ID

# Anthropic Claude配置
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# DeepSeek配置（可选，适用于国内）
DEEPSEEK_API_KEY=your-deepseek-api-key

# ========== 其他配置 ==========
# 根据需要配置其他支付提供商和地理分流设置
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com